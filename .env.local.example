# Required: Your Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Optional: Override the default model
# IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Optional: Shared secret to protect cache-miss generation (cache hits stay open)
# GEN_TOKEN=your_shared_secret_here

# Optional: Freemium rate limiting via Upstash Redis.
# If unset, rate limiting is disabled (fails open — unlimited generation).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Optional: Daily generation quotas (cache hits never counted)
# FREE_DAILY_LIMIT=5
# PREMIUM_DAILY_LIMIT=1000
