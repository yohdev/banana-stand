# Required: Google Cloud service account credentials (JSON) for Vertex AI
# Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON.
# Paste the entire JSON on one line. Vertex AI bills through standard
# Google Cloud billing (not AI Studio prepay credits).
GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Required: Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Optional: Vertex AI region (default us-central1 — widest image-model
# capacity). Switch regions here if you hit 429s or model-not-found.
# VERTEX_LOCATION=us-central1

# Optional: override the GCP project (defaults to project_id in the JSON)
# GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: Override the default model
# IMAGE_MODEL=gemini-2.5-flash-image

# Optional but recommended for any PUBLIC instance: shared secret that gates
# new image generation. When set, a cache miss requires the header
# `X-Gen-Token: <secret>`; cache hits stay open so existing images keep serving.
# Leave unset for a private/self-host instance where anyone may generate.
# GEN_TOKEN=your_shared_secret_here

# Optional: Prompt moderation before generation.
#   none (default) | keyword | openai
# MODERATION_PROVIDER=none
# Reject on provider error/outage instead of failing open:
# MODERATION_FAIL_CLOSED=false
# For "keyword" provider — comma-separated terms (overrides built-in defaults):
# MODERATION_DENYLIST=term1,term2,term3
# For "openai" provider — OpenAI key (Moderation API is free):
# OPENAI_API_KEY=your_openai_key_here

# Optional: public base URL of your deploy. Sets Open Graph metadata and the
# default host shown in the homepage copy-paste snippets.
# NEXT_PUBLIC_BASE_URL=https://your-instance.vercel.app

# Optional: GitHub token to raise the API rate limit for the /contributors
# page. Unauthenticated works too (60 requests/hour per IP).
# GITHUB_TOKEN=your_github_token_here

# Optional: enables the in-app feedback form (/feedback) to open issues in the
# repo. If unset, POST /api/feedback returns 503 (feature disabled).
# Token scopes:
#   - Fine-grained PAT: Issues -> Read and write, scoped to FEEDBACK_REPO
#   - Classic PAT: public_repo (public repo) or repo (private repo)
# Mark it Sensitive in Vercel. Keep it separate from the read-only GITHUB_TOKEN.
# GITHUB_FEEDBACK_TOKEN=your_write_scoped_github_token_here
# Repo that feedback issues are opened in (defaults to yohdev/banana-stand).
# FEEDBACK_REPO=yohdev/banana-stand
