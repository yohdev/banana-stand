# Required: Google Cloud service account credentials (JSON) for Vertex AI
# Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON.
# Paste the entire JSON on one line. Vertex AI bills through standard
# Google Cloud billing (not AI Studio prepay credits).
GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Required: Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Optional: Vertex AI region (default us-central1 — widest image-model
# capacity). Switch regions here if you hit 429s or model-not-found.
# VERTEX_LOCATION=us-central1

# Optional: override the GCP project (defaults to project_id in the JSON)
# GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: Override the default model
# IMAGE_MODEL=gemini-2.5-flash-image

# Optional: Shared secret to protect cache-miss generation (cache hits stay open)
# GEN_TOKEN=your_shared_secret_here

# Optional: Freemium rate limiting via Upstash Redis.
# If unset, rate limiting is disabled (fails open — unlimited generation).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Optional: Daily generation quotas (cache hits never counted)
# FREE_DAILY_LIMIT=5
# PREMIUM_DAILY_LIMIT=1000

# Optional: Prompt moderation before generation.
#   none (default) | keyword | openai
# MODERATION_PROVIDER=none
# Reject on provider error/outage instead of failing open:
# MODERATION_FAIL_CLOSED=false
# For "keyword" provider — comma-separated terms (overrides built-in defaults):
# MODERATION_DENYLIST=term1,term2,term3
# For "openai" provider — OpenAI key (Moderation API is free):
# OPENAI_API_KEY=your_openai_key_here
